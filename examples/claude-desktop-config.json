{
  "mcpServers": {
    "gitlab": {
      "command": "npx",
      "args": ["-y", "@alosies/gitlab-mcp-server"],
      "env": {
        "GITLAB_PERSONAL_ACCESS_TOKEN": "your-gitlab-token-here",
        "GITLAB_DEFAULT_PROJECT": "myorg/myproject",
        "GITLAB_MCP_PER_PAGE": "30"
      }
    }
  }
}